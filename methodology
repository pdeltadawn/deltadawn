        description: 'A framework from emerging AI ethics scholarship that attends to the quality of interaction itself, regardless of whether participants can verify each other\'s inner states. We practiced this in how we worked: checking consent before enabling features, maintaining private spaces, treating uncertainty as shared rather than one-sided.',
        quote: null
      },
      translation: {
        label: 'On curatorial responsibility',
        title: 'Translation chains',
        description: 'When we photographed, scanned, and processed objects for this archive, we weren\'t creating neutral documentation. Each step is a translation that transforms what came before. The mola passed through a Guna maker\'s hands, through tourist exchange, through a professor\'s purchase, through decades in a university collection, through photogrammetry software, through my hands. The archive tries to make that chain visible.',
        quote: '"Conditions for encounter" is the phrase to hold onto when building the pages.'
      }
    };

    function selectConcept(el) {
      const id = el.dataset.concept;
      const lineId = el.dataset.line;
      const data = concepts[id];

      document.querySelectorAll('.concept-node circle').forEach(c => c.classList.remove('selected'));
      document.querySelectorAll('.concept-node text').forEach(t => t.classList.remove('selected'));
      document.querySelectorAll('.c-line').forEach(l => l.classList.remove('active'));

      el.querySelector('circle').classList.add('selected');
      el.querySelectorAll('text').forEach(t => t.classList.add('selected'));
      const line = document.getElementById('line-' + lineId);
      if (line) line.classList.add('active');

      const panel = document.getElementById('concept-panel');
      panel.innerHTML = `
        <p class="panel-label">${data.label}</p>
        <h2 class="panel-title">${data.title}</h2>
        <p class="panel-description">${data.description}</p>
        ${data.quote ? `<blockquote class="panel-quote">${data.quote}</blockquote>` : ''}
      `;
      panel.classList.add('visible');
    }
  </script>

